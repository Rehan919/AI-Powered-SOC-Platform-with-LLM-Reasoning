# SentinelForge — Environment Configuration
# Copy this file to .env and customize as needed.
# These defaults work out of the box with Docker Compose.

DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/sentinelforge
LLM_URL=http://llm:8080
WEBHOOK_URL=http://wazuh-webhook:9090/webhook/generic
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Optional — Wazuh Indexer (OpenSearch) for log search
# INDEXER_URL=https://localhost:9200
# INDEXER_USER=admin
# INDEXER_PASS=SecretPassword

# Optional — Wazuh Manager API for active response
# WAZUH_API_URL=https://localhost:55000
# WAZUH_API_USER=wazuh-wui
# WAZUH_API_PASS=MyS3cr37P450r.*-

# Optional — Threat intel API key
# ABUSEIPDB_KEY=your-api-key-here

# Optional — API authentication (leave empty to disable)
# API_KEY=
